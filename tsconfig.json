{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/src/*"]
    },
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "types": ["google-apps-script", "node"]
  },
  "include": [
    "projects/**/*.ts",
    "projects/**/*.tsx",
    "projects/**/*.d.ts",
    "shared/**/*.ts"
  ],
  "exclude": [
    "projects/*/worker/**"
  ]
}
