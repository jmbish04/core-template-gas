{
  "name": "core-template-cfw-assets-astro-shadcn",
  "version": "26.06.24",
  "description": "The template helps you build apps with Astro, Tailwind CSS, and shadcn/ui.",
  "license": "MIT",
  "author": {
    "name": "126colby",
    "url": "https://github.com/126colby"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbish04/core-template-cfw-assets-astro-shadcn.git"
  },
  "scripts": {
    "config:generate": "node ../../../scripts/build-worker-config.mjs --project deep-research-companion",
    "dev": "pnpm run config:generate && astro dev",
    "build": "astro build",
    "preview": "pnpm run config:generate && wrangler dev",
    "start": "pnpm run dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "pnpm run config:generate && wrangler d1 migrations apply DB --local --config wrangler.generated.jsonc",
    "migrate:remote": "pnpm run config:generate && wrangler d1 migrations apply DB --remote --config wrangler.generated.jsonc",
    "deploy": "pnpm run build && cp .assetsignore dist/.assetsignore && pnpm run migrate:remote && wrangler deploy",
    "deploy:preview": "pnpm run build && cp .assetsignore dist/.assetsignore && pnpm run config:generate && wrangler versions upload",
    "cf-typegen": "pnpm run config:generate && wrangler types --config wrangler.generated.jsonc",
    "deps:lockfile": "corepack pnpm install --no-frozen-lockfile && pnpm run cf-typegen",
    "deps:update": "corepack pnpm update --latest && corepack pnpm install --no-frozen-lockfile && pnpm run cf-typegen"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.176",
    "@assistant-ui/react": "^0.12.28",
    "@assistant-ui/react-ai-sdk": "^1.3.21",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@base-ui/react": "^1.4.1",
    "@cloudflare/ai-chat": "0.7.1",
    "@cloudflare/workers-types": "^4.20260502.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@platejs/basic-nodes": "53.0.0",
    "@platejs/code-block": "53.0.0",
    "@platejs/indent": "53.0.0",
    "@platejs/link": "53.0.3",
    "@platejs/list": "53.1.3",
    "@scalar/hono-api-reference": "^0.10.13",
    "@shikijs/langs": "^4.3.0",
    "@shikijs/themes": "^4.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "agents": "0.12.4",
    "ai": "^6.0.174",
    "assistant-stream": "^0.3.15",
    "astro": "^5.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "0.8.3",
    "hono": "^4.12.16",
    "lucide-react": "^0.575.0",
    "mind-elixir": "5.13.0",
    "platejs": "53.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "recharts": "3.8.0",
    "remark-gfm": "^4.0.1",
    "remeda": "^2.39.0",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.62.0",
    "shadcn": "^4.6.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.87.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
