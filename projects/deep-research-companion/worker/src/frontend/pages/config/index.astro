---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="Configuration" description="Deep Research Companion configuration">
  <div class="container mx-auto max-w-5xl space-y-6 px-4 py-8">
    <div><p class="text-sm font-medium text-primary">Deep Research Companion</p><h1 class="mt-1 text-3xl font-semibold">Configuration</h1></div>
    <a href="/config/tags" class="block rounded-xl border bg-card p-6 transition-colors hover:bg-muted/40"><h2 class="font-semibold">Research tags</h2><p class="mt-1 text-sm text-muted-foreground">Create, color, activate, and retire tags used by the research archive.</p></a>
  </div>
</BaseLayout>
