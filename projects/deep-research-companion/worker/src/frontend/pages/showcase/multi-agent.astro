---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { MultiAgentPanel } from "@/components/showcase/MultiAgentPanel";
---

<BaseLayout
  title="Multi-Agent"
  description="An orchestrator that delegates tasks to researcher and coder subagents"
>
  <div class="container mx-auto max-w-7xl px-4 py-12">
    <header class="mb-8">
      <div class="mb-3 flex items-center gap-3">
        <h1 class="text-3xl font-bold tracking-tight">Multi-Agent</h1>
        <Badge variant="outline">orchestrator-agent</Badge>
      </div>
      <p class="max-w-2xl text-sm text-muted-foreground">
        Chat with the orchestrator and watch it delegate. When it routes a task
        to a specialist, it calls the
        <code class="text-primary">spawnTask</code> tool; the specialist's real
        conversation renders <strong>nested</strong> under that tool call —
        "Researcher Agent (working…)" then the sub-agent's reply, the assistant-ui
        Multi-Agent pattern. <code class="text-primary">getStats()</code> tracks the
        running delegation totals.
      </p>
    </header>

    <MultiAgentPanel client:only="react" />
  </div>
</BaseLayout>
