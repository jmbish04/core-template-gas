{
  "name": "core-template-gas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-project Google Apps Script workspace with a shared Apps Script library, React frontends, and affected-project CI/CD deploys.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node ./scripts/build-all.mjs",
    "build:project": "node ./scripts/build-project.mjs",
    "build:affected": "node ./scripts/build-affected.mjs",
    "deno:build": "deno task build",
    "deno:test": "deno test --config deno.jsonc main.test.ts",
    "deno:lock": "deno task lock",
    "deploy:project": "node ./scripts/deploy-project.mjs",
    "deploy:affected": "node ./scripts/deploy-affected.mjs",
    "deploy:worker": "node ./scripts/deploy-worker-project.mjs",
    "deploy:workers:affected": "node ./scripts/deploy-affected-workers.mjs",
    "projects:list": "node ./scripts/list-projects.mjs",
    "projects:affected": "node ./scripts/affected-projects.mjs",
    "projects:workers:affected": "node ./scripts/affected-worker-projects.mjs",
    "project:new": "node ./scripts/new-project.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "node ./scripts/validate-repo.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clasp:login": "npx clasp login"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@google/clasp": "^3.0.6",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "acorn": "^8.17.0",
    "esbuild": "^0.25.8",
    "esbuild-gas-plugin": "^0.8.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
