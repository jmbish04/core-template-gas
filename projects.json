{
  "version": 1,
  "appsscriptDefaults": {
    "projectId": "discovery-383518",
    "projectNumber": "791610499666",
    "rootDir": "./src",
    "fileExtension": "ts"
  },
  "rootImpactPaths": [
    "shared/",
    "scripts/",
    "appsscript.json",
    "projects.json",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    ".github/workflows/"
  ],
  "rootWorkerImpactPaths": [
    "wrangler.jsonc",
    "scripts/",
    "projects.json"
  ],
  "projects": [
    {
      "name": "workspace-admin",
      "displayName": "Workspace Admin",
      "path": "projects/workspace-admin",
      "serverEntry": "src/server/main.ts",
      "clientEntry": "src/client/main.tsx",
      "clientHtml": "src/client/index.html",
      "manifest": "appsscript.json",
      "secretKey": "workspace-admin"
    },
    {
      "name": "deep-research-companion",
      "displayName": "Deep Research Companion",
      "path": "projects/deep-research-companion",
      "serverEntry": "src/server/main.ts",
      "clientEntry": "src/client/main.tsx",
      "clientHtml": "src/client/index.html",
      "manifest": "appsscript.json",
      "secretKey": "deep-research-companion",
      "worker": {
        "path": "projects/deep-research-companion/worker",
        "installCommand": "corepack pnpm install --frozen-lockfile",
        "deployCommand": "corepack pnpm deploy",
        "typesCheckCommand": "corepack pnpm exec wrangler types --check --config wrangler.generated.jsonc"
      }
    }
  ]
}
